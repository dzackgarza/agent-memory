source "$HOME/.envrc"
export DIRENV_CONFIGURED_CORRECTLY=1
export JUST_WORKING_DIRECTORY="$(pwd -P)"
# Constrain uvx tool environments (including the QC gate's pytest) below pytest 9.
# pytest 9.1.x crashes collecting any module that uses `from __future__ import
# annotations` under Python 3.14. See constraints.txt for the full rationale.
export UV_CONSTRAINT="$(pwd -P)/constraints.txt"
